    "nuxt": "^4.4.2",
    "vue": "^3.5.32",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.2",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.3",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.9.0",
    "supabase": "^2.93.0",
    "tailwindcss": "^4.2.3",
