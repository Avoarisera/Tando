{
  "name": "waka-bods",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "bash tests/run.sh",
    "test:static": "bash tests/static-analysis.sh",
    "test:db": "bash tests/run.sh --db-only",
