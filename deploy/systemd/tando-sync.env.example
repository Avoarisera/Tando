# Copier vers /etc/tando/sync.env sur le VPS, puis remplir.
#   sudo install -Dm600 deploy/systemd/tando-sync.env.example /etc/tando/sync.env
#
# Générer un secret :  openssl rand -hex 32
# Le MÊME secret doit être présent dans l'environnement de l'app Nuxt (CRON_SECRET),
# sinon l'endpoint /api/cron/sync renverra 401.
CRON_SECRET=remplace-moi

# URL de l'endpoint cron. En local sur le VPS, tape directement le port Node (pas nginx).
SYNC_URL=http://127.0.0.1:3000/api/cron/sync
